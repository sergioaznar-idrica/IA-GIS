## 5. FLUJOS DE USO COMÚNES

### 5.1 Inicializar un Mapa Simple

```typescript
import { Map, MapContainer } from '@map-engine/react';

function App() {
    return (
        <MapContainer errorBoundary>
            <Map
                mapId="my-map"
                config={{
                    // Tu configuración
                }}
                environment="production"
                token="user-token"
                autoLoad={true}
                onMapReady={(map) => console.log('Map ready!', map)}
                onMapError={(error) => console.error('Map error:', error)}
            />
        </MapContainer>
    );
}
```

### 5.2 Agregar Capas Dinámicamente

```typescript
import { useMap, useMapLayers } from '@map-engine/react/hooks';

function MapComponent({ mapId }: { mapId: string }) {
    const { map } = useMap(mapId);
    const { addLayer } = useMapLayers(mapId);
    
    const handleAddWMS = () => {
        addLayer({
            id: 'new-wms',
            alias: 'New WMS Layer',
            layerType: 'WMS',
            url: 'https://...',
            layerName: 'layer_name'
        });
    };
    
    return (
        <button onClick={handleAddWMS}>Add WMS Layer</button>
    );
}
```

### 5.3 Interactuar con Capas

```typescript
function MapInteractions({ mapId }: { mapId: string }) {
    const { layers, setLayerVisibility, setLayerOpacity } = useMapLayers(mapId);
    const { enableHover } = useMapInteractions(mapId);
    
    useEffect(() => {
        enableHover({
            enabled: true,
            layerId: 'my-layer',
            highlightStyle: { color: 'red' }
        });
    }, []);
    
    return (
        <div>
            <input
                type="range"
                min="0"
                max="1"
                step="0.1"
                onChange={(e) => setLayerOpacity('my-layer', parseFloat(e.target.value))}
            />
        </div>
    );
}
```

