### 1.6 Puertos - Interface IMapLoader

**Ubicación:** `core/ports/IMapLoader.ts`

Define el contrato para cargar mapas.

```typescript
export interface LoadMapConfig {
    environment: string;              // Ej: 'production', 'staging'
    userToken: string;                // Token de autenticación
    mapConfig: MapConfig;             // Configuración del mapa
    useBackendFeatures?: boolean;     // Usar características del backend
    timeout?: number;                 // Timeout en milisegundos (default: 30000)
}

export interface IMapLoader {
    /**
     * Carga un mapa de forma asincrónica
     * @param mapId - Identificador único del mapa
     * @param config - Configuración de carga
     * @returns Promise con la instancia del mapa
     */
    loadMap(mapId: string, config: LoadMapConfig): Promise<NativeMapInstance>;
    
    /**
     * Obtiene un mapa ya cargado
     * @param mapId - Identificador del mapa
     * @returns Instancia del mapa o null
     */
    getMap(mapId: string): NativeMapInstance | null;
    
    /**
     * Verifica si un mapa está cargándose
     */
    isMapLoading(mapId: string): boolean;
    
    /**
     * Verifica si un mapa está listo
     */
    isMapReady(mapId: string): boolean;
    
    /**
     * Descarga un mapa y libera recursos
     */
    unloadMap(mapId: string): void;
}
```

